// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- SALES & CLIENT MODELS ---

enum PaymentStatus {
  PENDING
  CREDITED
  PAID_PARTIAL
}

model PriceTier {
  id                 String  @id @default(cuid())
  name               String  @unique
  description        String?
  discountPercentage Decimal @default(0) // e.g., 0.10 for 10% discount

  clients   Client[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id          String  @id @default(cuid())
  name        String  @unique
  address     String?
  phone       String?
  email       String?
  priceTierId String?

  priceTier   PriceTier?   @relation(fields: [priceTierId], references: [id], onDelete: Restrict)
  salesOrders SalesOrder[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model SalesOrder {
  id                String             @id @default(cuid())
  orderNumber       String             @unique // For a sales order number if needed (e.g., SO-YYYYMMDD-XXXX)
  clientId          String
  client            Client             @relation(fields: [clientId], references: [id])
  date              DateTime           @default(now())
  paymentStatus     PaymentStatus      @default(PENDING)
  salesPlatform     String? // "Plataforma de ventas" from Google Sheet
  notes             String? // "Notas" from Google Sheet
  totalAmount       Decimal // Total for the entire order
  items             SalesOrderItem[]
  inventoryMovement InventoryMovement? @relation("SalesMovementLink") // Inverse relation
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model SalesOrderItem {
  id           String     @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  quantity     Decimal
  unitPrice    Decimal // Price of this specific product in this sale
  totalPrice   Decimal // quantity * unitPrice
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Product {
  id                String      @id @default(cuid())
  internalCode      String      @unique
  description       String
  unit              String // "kg", "un", "mt", etc.
  priceUSD          Decimal?
  priceARS          Decimal?
  stock             Decimal     @default(0)
  lowStockThreshold Decimal     @default(0)
  isClassified      Boolean     @default(false)
  type              ProductType @default(RAW_MATERIAL)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId Int?

  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  supplierId Int?

  movements               InventoryMovement[]
  components              ProductComponent[]            @relation("isComponentFor")
  componentOf             ProductComponent[]            @relation("componentOf")
  externalProductionItems ExternalProductionOrderItem[]
  expectedInOrders        ExpectedProduction[]
  orderSentComponents     OrderSentComponent[] // NEW

  // Relation to assembly jobs (many-to-many)
  assemblyJobs    ProductAssemblyJob[]
  // Relación con los costos indirectos
  overheadCosts   ProductOverhead[]
  salesOrderItems SalesOrderItem[] // NEW inverse relation
  wastageLogs     WastageLog[]
}

model ProductComponent {
  product     Product @relation("isComponentFor", fields: [productId], references: [id])
  productId   String
  component   Product @relation("componentOf", fields: [componentId], references: [id])
  componentId String
  quantity    Decimal

  @@id([productId, componentId])
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Supplier {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  contactInfo String?
  products    Product[]
}

// --- MODELOS DE COSTOS AVANZADOS ---

model OverheadCost {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  cost        Decimal
  unit        String // e.g., "HORA", "UNIDAD"
  type        OverheadType @default(OTHER)

  products  ProductOverhead[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model ProductOverhead {
  product        Product      @relation(fields: [productId], references: [id])
  productId      String
  overheadCost   OverheadCost @relation(fields: [overheadCostId], references: [id])
  overheadCostId String
  quantity       Decimal

  @@id([productId, overheadCostId])
}

// --- ASSEMBLY & PRODUCTION MODELS ---

model AssemblyJob {
  id          String   @id @default(cuid())
  name        String   @unique
  price       Decimal
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation to the join table
  products           ProductAssemblyJob[]
  orderAssemblySteps OrderAssemblyStep[] // Relation to order steps
}

model ProductAssemblyJob {
  product       Product     @relation(fields: [productId], references: [id])
  productId     String      @unique
  assemblyJob   AssemblyJob @relation(fields: [assemblyJobId], references: [id])
  assemblyJobId String

  @@id([productId, assemblyJobId])
}

model ExternalProductionOrder {
  id                     String                        @id @default(cuid())
  orderNumber            String                        @unique
  assemblerId            String
  dateSent               DateTime
  expectedCompletionDate DateTime?
  status                 ExternalProductionOrderStatus @default(PENDING_DELIVERY)
  notes                  String?
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt

  deliveryUserId Int?
  deliveryUser   User? @relation("Deliveries", fields: [deliveryUserId], references: [id])

  pickupUserId Int?
  pickupUser   User? @relation("Pickups", fields: [pickupUserId], references: [id])

  assembler          Assembler                     @relation(fields: [assemblerId], references: [id])
  items              ExternalProductionOrderItem[]
  expectedOutputs    ExpectedProduction[]
  assemblySteps      OrderAssemblyStep[] // Relation to assembly steps
  inventoryMovements InventoryMovement[] // New inverse relation
  orderNotes         OrderNote[] // NEW

  assemblerPaymentId  String?
  orderSentComponents OrderSentComponent[] // NEW

  assemblerPayment AssemblerPayment? @relation(fields: [assemblerPaymentId], references: [id])
  alerts           Alert[]
  wastageLogs      WastageLog[]
}

model ExternalProductionOrderItem {
  id                        String  @id @default(cuid())
  externalProductionOrderId String
  productId                 String // Component sent
  quantitySent              Decimal

  order   ExternalProductionOrder @relation(fields: [externalProductionOrderId], references: [id], onDelete: Cascade)
  product Product                 @relation(fields: [productId], references: [id])

  @@unique([externalProductionOrderId, productId])
}

model ExpectedProduction {
  id                        String   @id @default(cuid())
  externalProductionOrderId String
  productId                 String
  quantityExpected          Decimal
  quantityReceived          Decimal  @default(0)
  createdAt                 DateTime @default(now())

  order   ExternalProductionOrder @relation(fields: [externalProductionOrderId], references: [id], onDelete: Cascade)
  product Product                 @relation(fields: [productId], references: [id])

  @@unique([externalProductionOrderId, productId])
}

model OrderAssemblyStep {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal // NEW - Renamed from precioUnitario

  externalProductionOrderId String
  externalProductionOrder   ExternalProductionOrder @relation(fields: [externalProductionOrderId], references: [id], onDelete: Cascade)

  assemblyJobId String
  assemblyJob   AssemblyJob @relation(fields: [assemblyJobId], references: [id])

  @@index([externalProductionOrderId])
  @@index([assemblyJobId])
}

model OrderSentComponent {
  id                        String @id @default(cuid())
  externalProductionOrderId String
  productId                 String
  quantitySent              Int

  externalProductionOrder ExternalProductionOrder @relation(fields: [externalProductionOrderId], references: [id])
  product                 Product                 @relation(fields: [productId], references: [id])

  @@unique([externalProductionOrderId, productId])
}

model OrderNote {
  id                        String                  @id @default(cuid())
  content                   String
  authorId                  Int
  author                    User                    @relation(fields: [authorId], references: [id])
  externalProductionOrderId String
  externalProductionOrder   ExternalProductionOrder @relation(fields: [externalProductionOrderId], references: [id], onDelete: Cascade)
  createdAt                 DateTime                @default(now())
}

model AssemblerPayment {
  id          String   @id @default(cuid())
  assemblerId String
  datePaid    DateTime
  amount      Decimal
  periodStart DateTime
  periodEnd   DateTime
  notes       String?
  createdAt   DateTime @default(now())

  assembler Assembler                 @relation(fields: [assemblerId], references: [id])
  orders    ExternalProductionOrder[] // Relation to paid orders
}

model Assembler {
  id           String       @id @default(cuid())
  name         String       @unique
  contactInfo  String?
  address      String?
  phone        String?
  email        String?
  paymentTerms PaymentTerms
  tracerCode   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  externalProductionOrders ExternalProductionOrder[]
  assemblerPayments        AssemblerPayment[]
  wastageLogs              WastageLog[]
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movements          InventoryMovement[]
  assignedDeliveries ExternalProductionOrder[] @relation("Deliveries")
  assignedPickups    ExternalProductionOrder[] @relation("Pickups")
  orderNotes         OrderNote[] // NEW
  wastageLogs        WastageLog[]
}

model InventoryMovement {
  id                        Int          @id @default(autoincrement())
  productId                 String
  type                      MovementType
  quantity                  Decimal
  userId                    Int
  notes                     String?
  createdAt                 DateTime     @default(now())
  eventId                   String?
  externalProductionOrderId String? // New field
  salesOrderId              String?      @unique // New field, unique for 1:1 link to SalesOrder

  product                 Product                  @relation(fields: [productId], references: [id])
  user                    User                     @relation(fields: [userId], references: [id])
  externalProductionOrder ExternalProductionOrder? @relation(fields: [externalProductionOrderId], references: [id]) // New relation
  salesOrder              SalesOrder?              @relation("SalesMovementLink", fields: [salesOrderId], references: [id]) // New relation

  @@index([eventId])
  @@index([externalProductionOrderId]) // New index for the relation
  @@index([salesOrderId]) // New index for the sales order relation
}

model OrderSequence {
  date         String @id // YYYY-MM-DD
  lastSequence Int
}

// --- ENUMS ---

enum PaymentTerms {
  BI_WEEKLY
  MONTHLY
  PER_UNIT
}

enum Role {
  ADMIN
  SUPERVISOR
  EMPLOYEE
}

enum ProductType {
  RAW_MATERIAL
  PRE_ASSEMBLED
  FINISHED
}

enum MovementType {
  PURCHASE
  PRODUCTION_IN
  CUSTOMER_RETURN
  ADJUSTMENT_IN
  SENT_TO_ASSEMBLER
  RECEIVED_FROM_ASSEMBLER
  PRODUCTION_OUT
  SALE
  WASTAGE
  ADJUSTMENT_OUT
}

enum ExternalProductionOrderStatus {
  PENDING_DELIVERY
  OUT_FOR_DELIVERY
  DELIVERY_FAILED
  IN_ASSEMBLY
  PENDING_PICKUP
  RETURN_IN_TRANSIT
  PARTIALLY_RECEIVED // The order has been partially received
  COMPLETED
  COMPLETED_WITH_NOTES
  COMPLETED_WITH_DISCREPANCY
  CANCELLED
}

enum QualityStatus {
  OK
  DEFECTIVE
  PARTIAL_OK
}

enum OverheadType {
  MACHINE_HOUR
  SERVICE
  DESIGN
  OTHER
}

enum AlertType {
  INACTIVITY
  LOW_STOCK
  QUALITY_ISSUE
  OTHER
}

enum AlertStatus {
  ACTIVE
  DISMISSED
  RESOLVED
}

model Alert {
  id        String      @id @default(cuid())
  type      AlertType   @default(INACTIVITY)
  message   String
  status    AlertStatus @default(ACTIVE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relación con Orden de Producción Externa si aplica
  externalProductionOrderId String?
  externalProductionOrder   ExternalProductionOrder? @relation(fields: [externalProductionOrderId], references: [id], onDelete: Cascade)

  @@index([externalProductionOrderId])
  @@index([status])
}

model WastageLog {
  id           String   @id @default(cuid())
  quantity     Decimal
  reason       String
  costDeducted Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id])

  assemblerId String?
  assembler   Assembler? @relation(fields: [assemblerId], references: [id])

  externalProductionOrderId String?
  externalProductionOrder   ExternalProductionOrder? @relation(fields: [externalProductionOrderId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@index([assemblerId])
  @@index([externalProductionOrderId])
  @@index([costDeducted])
}
